# Token del bot de Telegram (obténlo de @BotFather → /newbot)
TELEGRAM_BOT_TOKEN=

# IDs de Telegram autorizados a usar el bot, separados por coma
# Obtén tu ID enviando un mensaje a @userinfobot
TELEGRAM_ALLOWED_USERS=

# URL base de tu WordPress (sin barra al final)
WORDPRESS_URL=https://deportesdo.com

# Usuario de WordPress (tu nombre de usuario en wp-admin)
WORDPRESS_USERNAME=

# Application Password generado en: wp-admin → Usuarios → Tu perfil → Application Passwords
# Formato: xxxx xxxx xxxx xxxx xxxx xxxx (con espacios, tal como lo copia WordPress)
WORDPRESS_APP_PASSWORD=

# API Key de Anthropic (console.anthropic.com → API Keys → Create Key)
ANTHROPIC_API_KEY=
