# Dominio del sitio WordPress.com (sin https://, ej: armatusemestre.wordpress.com)
WP_SITE_URL=tu-sitio.wordpress.com

# Usuario de WordPress.com
WP_USERNAME=tu-usuario

# Application Password generado en: Perfil → Seguridad → Application Passwords
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# Opcional: correr solo con un campus para pruebas (ej: CSA)
# WP_TEST_CAMPUS=CSA
