{
  "expo": {
    "name": "TanqueLleno",
    "slug": "tanquelleno",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./src/assets/icon.png",
    "splash": {
      "backgroundColor": "#07091A",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "do.tanquelleno.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#07091A"
      },
      "package": "do.tanquelleno.app"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-font"
    ]
  }
}
